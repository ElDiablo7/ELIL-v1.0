# ENLIL™ Environment Configuration
# Copy to .env and configure for your deployment

# Server
NODE_ENV=development
PORT=3000

# Mode: 'demo' or 'production'
# demo = uses preset demo accounts, relaxed security
# production = requires ENLIL_USERS env, strict security
ENLIL_MODE=demo

# Security Secrets (CHANGE THESE IN PRODUCTION)
JWT_SECRET=change-this-to-a-64-char-random-string-in-production
SESSION_SECRET=change-this-to-another-64-char-random-string
AUDIT_SECRET=change-this-to-a-unique-audit-signing-secret

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Audit Logging
# Options: 'local' (in-memory only), 'file' (JSON file), 'database' (future)
AUDIT_LOG_MODE=file

# TITAN Risk Provider
# Options: 'rule-based' (offline), 'llm' (requires API key, future)
TITAN_PROVIDER=rule-based

# Production Users (JSON format, only used when ENLIL_MODE=production)
# Example:
# ENLIL_USERS={"admin":{"password":"secure-password-here","role":"ADMIN"},"owner":{"password":"owner-password","role":"OWNER"}}
