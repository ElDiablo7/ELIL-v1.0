# =====================================================================
# ENLIL™ AI Governance Console — Environment Configuration
# =====================================================================
# Copy this file to .env and configure for your deployment.
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =====================================================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Mode ---
# 'demo'       = Uses preset demo accounts (owner/admin/operator/viewer)
# 'production' = Requires ENLIL_USERS env, strict secret validation
ENLIL_MODE=demo

# --- Security Secrets ---
# CRITICAL: Change ALL secrets before production deployment.
# Each must be at least 32 characters. Use random hex strings.
# The server will REFUSE TO START in production mode if these are weak or missing.

# JWT_SECRET: Signs authentication tokens. Must be unique per deployment.
JWT_SECRET=change-this-to-a-64-char-random-string-in-production

# SESSION_SECRET: Used for session management. Must differ from JWT_SECRET.
SESSION_SECRET=change-this-to-another-64-char-random-string

# AUDIT_SECRET: Signs the tamper-evident audit hash chain via HMAC.
# This secret is also needed by `npm run verify:audit` to check HMAC signatures.
# If not set, a random value is generated per server restart (audit HMAC will not
# persist across restarts unless this is explicitly configured).
AUDIT_SECRET=change-this-to-a-unique-audit-signing-secret

# --- CORS ---
# Comma-separated list of allowed origins. In production, set to your domain only.
ALLOWED_ORIGINS=http://localhost:3000

# --- Audit Logging ---
# 'file'     = JSON file persistence (default, suitable for demo/pilot)
# 'local'    = In-memory only (lost on restart)
# 'database' = PostgreSQL (future — not yet implemented)
AUDIT_LOG_MODE=file

# --- TITAN Risk Provider ---
# 'rule-based' = Offline pattern-matching (default, always available)
# 'llm'        = LLM provider (requires API key — future)
TITAN_PROVIDER=rule-based

# --- Production Users ---
# Required when ENLIL_MODE=production. JSON object mapping usernames to credentials.
# Demo credentials are BLOCKED in production mode — only ENLIL_USERS are accepted.
# Passwords are hashed with SHA-256 on login comparison.
#
# Example:
# ENLIL_USERS={"admin":{"password":"your-secure-password","role":"ADMIN","displayName":"Admin User"},"owner":{"password":"owner-secure-password","role":"OWNER","displayName":"System Owner"}}
