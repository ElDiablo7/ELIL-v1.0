      "name": "Credential Harvesting via Social Engineering",
      "attacker_goal": "Obtain valid credentials through phishing or social manipulation",
      "operator_mistake_pattern": "Clicking suspicious links, sharing credentials, weak password policies",
      "detection_signals": [
        "Unusual login locations",
        "Multiple failed authentication attempts",
        "Credential reuse across systems",
        "Phishing email indicators"
      ],
      "recommended_controls": [
        "Multi-factor authentication",
        "User security awareness training",
        "Email filtering and scanning",
        "Password policy enforcement",
        "Account monitoring"
      ]
    },
