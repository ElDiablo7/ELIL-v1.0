{
  "system": {
    "name": "GRACE-X TITAN + SENTINEL",
    "version": "1.0.0",
    "mode": "SENTINEL",
    "titan_locked": false
  },
  "authentication": {
    "default_pin": "0000",
    "max_attempts": 9999,
    "lockout_duration": 300,
    "session_timeout": 3600
  },
  "logging": {
    "enabled": true,
    "max_entries": 10000,
    "export_format": "json",
    "hash_algorithm": "sha256"
  },
  "policy": {
    "default_pack": "gov_secure",
    "auto_load": true
  },
  "posture": {
    "initial": "GREEN",
    "update_on_risk": true
  },
  "rate_limiting": {
    "enabled": true,
    "max_requests_per_minute": 20,
    "max_requests_per_hour": 500
  },
  "titan": {
    "auto_invoke_threshold": 30,
    "require_authorization": true,
    "classification_default": "TOP_SECRET"
  },
  "ui": {
    "theme": "sci_fi",
    "animations_enabled": true,
    "scanline_enabled": true,
    "starfield_enabled": true
  },
  "offline_mode": {
    "enabled": true,
    "external_connectors_stubbed": true,
    "warn_on_external_attempt": true
  }
}
